# Sandbox Doc Bot - 환경변수 설정 예시
# 이 파일을 복사해 .env 파일을 만들고 실제 값을 입력하세요.
# cp .env.example .env

# ─── Slack ───────────────────────────────────────────────────────────────────
# Slack 앱 설정 페이지(api.slack.com/apps)에서 발급
DOC_BOT_TOKEN=xoxb-xxxxxxxxxx        # Bot User OAuth Token
DOC_APP_TOKEN=xapp-xxxxxxxxxx        # App-Level Token (Socket Mode)

# ─── 채널 ID (기본값이 있으므로 변경 필요 시만 입력) ──────────────────────────
# HELPDESK_CHANNEL=C03E08UCZS6       # 헬프데스크 채널
# TEAM_CHANNEL=C08823F52U8           # GA 팀 채널

# ─── Notion ───────────────────────────────────────────────────────────────────
NOTION_TOKEN=secret_xxxxxxxxxx       # Notion Integration Token

# ─── 운영 모드 ─────────────────────────────────────────────────────────────────
TEST_MODE=true                       # true: 팀채널 미리보기 / false: 헬프데스크 즉시 답변
